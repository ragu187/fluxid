FLUXID_NEO_API_KEY=your_kotak_neo_api_key
FLUXID_NEO_TOFT_KEY=optional_toft_key
FLUXID_NEO_API_BASE_URL=https://api.kotaksecurities.com/neo
FLUXID_REFRESH_SECONDS=15
FLUXID_INDIA_TICKERS=NIFTY_SPOT,BANKNIFTY_SPOT
FLUXID_US_TICKERS=SPY,QQQ,DIA,IWM,AAPL,MSFT,NVDA,TSLA
FLUXID_ENABLE_US_FEED=true

# Alpaca Market Data API — used for the US equities feed.
# Sign up for free at https://alpaca.markets to obtain your key pair.
# Free IEX feed (15-min delayed) works with no paid subscription.
# Upgrade to FLUXID_ALPACA_FEED=sip for real-time SIP data (paid plan required).
FLUXID_ALPACA_API_KEY_ID=your_alpaca_api_key_id
FLUXID_ALPACA_API_SECRET_KEY=your_alpaca_api_secret_key
FLUXID_ALPACA_DATA_BASE_URL=https://data.alpaca.markets
FLUXID_ALPACA_FEED=iex
